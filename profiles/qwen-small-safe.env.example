# Safe defaults for smaller open-source models.
# Source manually or export selected variables before running Codex master-worker flows.
# MODEL_NAME can be omitted because the runtime scripts auto-detect an installed local model.

export OPENAI_API_KEY=dummy-key
export OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Master planner
export ORCH_MAX_FILES_PER_JOB=2
export ORCH_MAX_JOBS=3
export ORCH_INVENTORY_LIMIT=12

# Guarded master Codex
export GUARD_MAX_FILES=2
export GUARD_MAX_LINES_PER_FILE=160
export GUARD_MAX_BATCHES=2

# Worker fallback behavior
export API_TIMEOUT_MS=600000
